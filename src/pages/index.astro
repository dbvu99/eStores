---
import Layout from "../layouts/Layout.astro";

const stats = [
  { value: "2h", label: "Giao nội thành" },
  { value: "200+", label: "Mẫu quà tặng" },
  { value: "4.9/5", label: "Đánh giá khách hàng" },
];

const highlights = [
  {
    title: "Trái cây nhập khẩu",
    text: "Chọn lọc tươi mới mỗi ngày, đóng gói đẹp mắt, phù hợp biếu tặng và sử dụng gia đình.",
  },
  {
    title: "Giỏ quà doanh nghiệp",
    text: "Thiết kế sang trọng, dễ cá nhân hoá, thích hợp tri ân đối tác, nhân sự và khách hàng.",
  },
  {
    title: "Giao nhanh trong ngày",
    text: "Đặt trước buổi sáng, giao trong khung giờ linh hoạt để giữ trọn độ tươi ngon.",
  },
];

const collections = [
  {
    title: "Giỏ trái cây premium",
    text: "Thiết kế chỉn chu cho khai trương, chúc mừng và những dịp cần sự tinh tế.",
    badge: "Best seller",
  },
  {
    title: "Hộp quà sức khoẻ",
    text: "Phù hợp tặng gia đình, sếp, đồng nghiệp hoặc mang tới bệnh viện, văn phòng.",
    badge: "Gift ready",
  },
  {
    title: "Combo theo mùa",
    text: "Đổi mới từng tuần với trái cây theo mùa để luôn có lựa chọn ngon và hợp túi tiền.",
    badge: "Fresh pick",
  },
  {
    title: "Đơn hàng doanh nghiệp",
    text: "Hỗ trợ số lượng lớn, in thiệp theo yêu cầu và tư vấn set quà theo ngân sách.",
    badge: "B2B",
  },
];

const steps = [
  {
    step: "01",
    title: "Chọn mẫu ưa thích",
    text: "Duyệt danh mục, xem ảnh thật và chọn set quà phù hợp với dịp tặng.",
  },
  {
    step: "02",
    title: "Xác nhận nhanh",
    text: "Điền thông tin người nhận, khung giờ giao và lời nhắn nếu cần.",
  },
  {
    step: "03",
    title: "Giao tận tay",
    text: "Đóng gói cẩn thận, giao đúng hẹn, giữ vẻ ngoài đẹp và độ tươi tốt nhất.",
  },
];

const testimonials = [
  {
    quote:
      "Giao diện nhìn rất cao cấp, dễ xem sản phẩm và phần quà tặng làm mình muốn đặt ngay.",
    name: "Ngọc Anh",
    role: "Khách hàng cá nhân",
  },
  {
    quote:
      "Mình thích kiểu bố cục rõ ràng, sang và không bị rối. Rất hợp trang bán quà trái cây.",
    name: "Minh Đức",
    role: "Quản lý mua hàng",
  },
  {
    quote:
      "Phần hero và card sản phẩm nổi bật, nhìn chuyên nghiệp như một brand premium thật sự.",
    name: "Thu Hà",
    role: "Owner shop quà tặng",
  },
];
---

<Layout
  title="eStores | Giao diện home hiện đại"
  description="Trang chủ eStores với phong cách hiện đại, sang trọng và tối ưu cho bán hàng."
>
  <main class="overflow-hidden">
    <section class="relative isolate">
      <div class="absolute inset-0 -z-10">
        <div class="absolute rounded-full hero-orb hero-orb--one"></div>
        <div class="absolute rounded-full hero-orb hero-orb--two"></div>
      </div>

      <div class="mx-auto grid max-w-7xl gap-12 px-4 pb-16 pt-8 lg:grid-cols-[1.05fr_0.95fr] lg:px-6 lg:pb-24 lg:pt-14">
        <div class="flex flex-col justify-center">
          <div class="inline-flex w-fit items-center gap-2 rounded-full border border-primary/15 bg-white/80 px-4 py-2 text-sm font-semibold text-primary shadow-sm backdrop-blur">
            <span class="h-2.5 w-2.5 rounded-full bg-secondary"></span>
            Giao diện mới cho eStores
          </div>

          <h1 class="mt-5 max-w-2xl text-5xl font-black leading-[0.95] tracking-tight text-slate-900 sm:text-6xl xl:text-7xl">
            Trải nghiệm mua sắm
            <span class="text-primary">tươi mới</span>
            và sang trọng hơn.
          </h1>

          <p class="mt-6 max-w-xl text-lg leading-8 text-slate-600">
            Một home page đậm chất thương mại điện tử: hero nổi bật, danh mục rõ
            ràng, khối lợi ích tinh gọn và CTA mạnh để khách vào xem sản phẩm ngay.
          </p>

          <div class="mt-8 flex flex-wrap gap-3">
            <a
              href="#collections"
              class="inline-flex items-center justify-center rounded-full bg-primary px-6 py-3 text-sm font-bold text-primary-content shadow-lg shadow-primary/20 transition hover:-translate-y-0.5 hover:bg-[#01424e]"
            >
              Khám phá bộ sưu tập
            </a>
            <a
              href="#contact"
              class="inline-flex items-center justify-center rounded-full border border-primary/15 bg-white px-6 py-3 text-sm font-bold text-primary transition hover:-translate-y-0.5 hover:border-primary/30 hover:bg-primary/5"
            >
              Nhận tư vấn
            </a>
          </div>

          <div class="mt-10 grid gap-4 sm:grid-cols-3">
            {stats.map((item) => (
              <div class="rounded-3xl border border-white/60 bg-white/80 p-5 shadow-sm backdrop-blur">
                <div class="text-2xl font-black text-slate-900">{item.value}</div>
                <div class="mt-1 text-sm text-slate-600">{item.label}</div>
              </div>
            ))}
          </div>
        </div>

        <div class="relative">
          <div class="absolute -left-6 top-10 hidden rounded-full border border-white/70 bg-white/80 px-4 py-3 shadow-lg backdrop-blur lg:block">
            <p class="text-xs uppercase tracking-[0.3em] text-slate-500">Fresh drop</p>
            <p class="mt-1 text-sm font-bold text-slate-900">Bộ quà mùa mới</p>
          </div>

          <div class="absolute -right-4 bottom-8 hidden rounded-full bg-secondary px-4 py-3 text-sm font-bold text-secondary-content shadow-lg shadow-secondary/30 lg:block">
            Miễn phí thiệp chúc
          </div>

          <div class="relative overflow-hidden rounded-[2rem] border border-white/70 bg-white/80 p-4 shadow-[0_30px_80px_rgba(1,80,95,0.16)] backdrop-blur">
            <div class="grid gap-4 md:grid-cols-[1.05fr_0.95fr]">
              <div class="relative overflow-hidden rounded-[1.75rem] bg-slate-900 p-6 text-white">
                <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(229,166,79,0.35),transparent_34%),radial-gradient(circle_at_bottom_left,rgba(255,255,255,0.12),transparent_28%)]"></div>
                <div class="relative">
                  <p class="text-xs uppercase tracking-[0.3em] text-white/70">Featured set</p>
                  <h2 class="mt-4 text-3xl font-black leading-tight">
                    Hộp quà trái cây cao cấp
                  </h2>
                  <p class="mt-3 max-w-xs text-sm leading-7 text-white/80">
                    Phối màu sang, bố cục đẹp, rất hợp cho khai trương, thăm hỏi và tri ân.
                  </p>
                </div>

                <div class="mt-8 grid grid-cols-3 gap-3">
                  <div class="rounded-2xl bg-white/10 p-4 backdrop-blur">
                    <div class="text-lg font-black">24h</div>
                    <div class="mt-1 text-xs text-white/70">Xử lý đơn</div>
                  </div>
                  <div class="rounded-2xl bg-white/10 p-4 backdrop-blur">
                    <div class="text-lg font-black">100%</div>
                    <div class="mt-1 text-xs text-white/70">Ảnh thật</div>
                  </div>
                  <div class="rounded-2xl bg-white/10 p-4 backdrop-blur">
                    <div class="text-lg font-black">5★</div>
                    <div class="mt-1 text-xs text-white/70">Thiết kế</div>
                  </div>
                </div>
              </div>

              <div class="grid gap-4">
                <img
                  src="https://images.unsplash.com/photo-1610832958506-aa56368176cf?auto=format&fit=crop&w=1200&q=80"
                  alt="Giỏ trái cây cao cấp"
                  class="h-full min-h-[18rem] w-full rounded-[1.75rem] object-cover"
                />
                <div class="grid gap-4 sm:grid-cols-2">
                  <div class="rounded-[1.5rem] border border-slate-200 bg-white p-5">
                    <p class="text-sm font-semibold text-primary">Đặc điểm</p>
                    <p class="mt-2 text-sm leading-7 text-slate-600">
                      Tươi ngon, sang trọng, dễ tùy biến theo ngân sách.
                    </p>
                  </div>
                  <div class="rounded-[1.5rem] border border-slate-200 bg-primary/5 p-5">
                    <p class="text-sm font-semibold text-primary">Phong cách</p>
                    <p class="mt-2 text-sm leading-7 text-slate-600">
                      Clean, premium, nhiều khoảng thở và CTA rõ ràng.
                    </p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="mx-auto max-w-7xl px-4 pb-8 lg:px-6">
      <div class="grid gap-4 rounded-[2rem] border border-slate-200/80 bg-white/85 p-5 shadow-sm backdrop-blur md:grid-cols-3">
        {highlights.map((item) => (
          <article class="rounded-[1.5rem] bg-slate-50 p-6">
            <div class="inline-flex h-11 w-11 items-center justify-center rounded-2xl bg-primary text-sm font-black text-white">
              e
            </div>
            <h2 class="mt-5 text-xl font-black text-slate-900">{item.title}</h2>
            <p class="mt-3 text-sm leading-7 text-slate-600">{item.text}</p>
          </article>
        ))}
      </div>
    </section>

    <section id="collections" class="mx-auto max-w-7xl px-4 py-16 lg:px-6">
      <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
        <div>
          <p class="text-sm font-bold uppercase tracking-[0.25em] text-primary">Collections</p>
          <h2 class="mt-2 text-3xl font-black text-slate-900 sm:text-4xl">
            Bộ sưu tập được trình bày rõ và đẹp
          </h2>
        </div>
        <p class="max-w-xl text-sm leading-7 text-slate-600">
          Mỗi khối đều được thiết kế để khách nhìn nhanh hiểu ngay giá trị, phù hợp
          trang home bán hàng hiện đại.
        </p>
      </div>

      <div class="mt-8 grid gap-4 md:grid-cols-2 xl:grid-cols-4">
        {collections.map((item) => (
          <article class="group rounded-[1.75rem] border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-xl">
            <div class="flex items-center justify-between">
              <span class="rounded-full bg-primary/10 px-3 py-1 text-xs font-bold text-primary">
                {item.badge}
              </span>
              <span class="h-10 w-10 rounded-2xl bg-gradient-to-br from-primary to-secondary opacity-90"></span>
            </div>
            <h3 class="mt-6 text-xl font-black text-slate-900">{item.title}</h3>
            <p class="mt-3 text-sm leading-7 text-slate-600">{item.text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="bg-white/70 py-16">
      <div class="mx-auto max-w-7xl px-4 lg:px-6">
        <div class="grid gap-6 lg:grid-cols-[0.85fr_1.15fr]">
          <div class="rounded-[2rem] bg-slate-900 p-8 text-white">
            <p class="text-sm font-bold uppercase tracking-[0.25em] text-white/60">Why us</p>
            <h2 class="mt-3 text-3xl font-black leading-tight">
              Tối ưu cho bán hàng, đẹp cho thương hiệu.
            </h2>
            <p class="mt-4 max-w-md text-sm leading-7 text-white/75">
              Giao diện này đi theo hướng premium, sáng, sạch, phù hợp cho shop quà
              tặng hoặc thương hiệu muốn nhìn chuyên nghiệp hơn ngay từ trang đầu.
            </p>
          </div>

          <div class="grid gap-4 sm:grid-cols-2">
            {steps.map((item) => (
              <article class="rounded-[1.75rem] border border-slate-200 bg-white p-6">
                <div class="text-sm font-black tracking-[0.25em] text-secondary">{item.step}</div>
                <h3 class="mt-4 text-xl font-black text-slate-900">{item.title}</h3>
                <p class="mt-3 text-sm leading-7 text-slate-600">{item.text}</p>
              </article>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="mx-auto max-w-7xl px-4 py-16 lg:px-6">
      <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
        <div>
          <p class="text-sm font-bold uppercase tracking-[0.25em] text-primary">
            Feedback
          </p>
          <h2 class="mt-2 text-3xl font-black text-slate-900 sm:text-4xl">
            Khách hàng cảm nhận gì?
          </h2>
        </div>
      </div>

      <div class="mt-8 grid gap-4 lg:grid-cols-3">
        {testimonials.map((item) => (
          <blockquote class="rounded-[1.75rem] border border-slate-200 bg-white p-6 shadow-sm">
            <p class="text-sm leading-7 text-slate-600">“{item.quote}”</p>
            <footer class="mt-6 border-t border-slate-100 pt-4">
              <div class="font-bold text-slate-900">{item.name}</div>
              <div class="text-sm text-slate-500">{item.role}</div>
            </footer>
          </blockquote>
        ))}
      </div>
    </section>

    <section id="contact" class="px-4 pb-16 lg:px-6">
      <div class="mx-auto max-w-7xl overflow-hidden rounded-[2.25rem] bg-[linear-gradient(135deg,#01505f_0%,#0f7a8a_55%,#e5a64f_100%)] p-8 text-white shadow-[0_32px_90px_rgba(1,80,95,0.28)] sm:p-10">
        <div class="grid gap-8 lg:grid-cols-[1.15fr_0.85fr] lg:items-center">
          <div>
            <p class="text-sm font-bold uppercase tracking-[0.25em] text-white/70">
              Ready to launch
            </p>
            <h2 class="mt-3 text-3xl font-black sm:text-5xl">
              Sẵn sàng đưa home page của bạn lên level mới?
            </h2>
            <p class="mt-4 max-w-2xl text-sm leading-7 text-white/80">
              Nếu bạn muốn, mình có thể chỉnh tiếp thành theme sang hơn nữa, thêm
              section sản phẩm thật, hoặc chuyển sang kiểu tối giản cao cấp.
            </p>
          </div>

          <div class="rounded-[1.75rem] bg-white/10 p-6 backdrop-blur">
            <div class="text-sm font-semibold text-white/70">Liên hệ nhanh</div>
            <div class="mt-3 text-2xl font-black">Hotline / Zalo / Website</div>
            <div class="mt-4 flex flex-wrap gap-3">
              <a
                href="tel:0900000000"
                class="inline-flex items-center justify-center rounded-full bg-white px-5 py-3 text-sm font-bold text-primary transition hover:-translate-y-0.5"
              >
                Gọi ngay
              </a>
              <a
                href="mailto:hello@estores.vn"
                class="inline-flex items-center justify-center rounded-full border border-white/30 px-5 py-3 text-sm font-bold text-white transition hover:-translate-y-0.5 hover:bg-white/10"
              >
                Xem demo
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .hero-orb {
    filter: blur(70px);
    opacity: 0.8;
  }

  .hero-orb--one {
    top: -4rem;
    left: -6rem;
    width: 18rem;
    height: 18rem;
    background: rgb(229 166 79 / 34%);
  }

  .hero-orb--two {
    right: -5rem;
    top: 10rem;
    width: 20rem;
    height: 20rem;
    background: rgb(1 80 95 / 18%);
  }
</style>
